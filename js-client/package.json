{
  "name": "root-e2ee-protocol",
  "version": "0.1.2",
  "description": "End-to-end encrypted request/response protocol for ROOT.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "types"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build:types"
  },
  "dependencies": {
    "cbor-x": "^1.5.9"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/therealPaulPlay/root-e2ee-protocol.git"
  }
}
